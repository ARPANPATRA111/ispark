# nyc test coverage
.nyc_output

# Grunt folders
.grunt

# Bower dependency directory
bower_components

# node-modules
node_modules/
jspm_packages/

# Snowpack dependency directory
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
# Ignore .env and every variant (.env.local, .env.supabase, ...) so a new
# environment file can never be committed by accident. Templates ending in
# .example are deliberately kept.
.env
.env.*
!*.example

# svelte-kit files
.svelte-kit/

# Vite build output
/web/build/
/web/.svelte-kit/
/web/node_modules/

# Go output
/api/bin/
/api/api
/api/tmp/
/api/.env
# Runtime certificate upload storage (seeded + user-uploaded files)
/api/uploads/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Supabase CLI local artifacts
supabase/.temp/
supabase/.branches/

# Vercel CLI local artifacts
.vercel/

# IDEs and editors
.idea/
.vscode/*
!.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.vscode
mks/
mz/
