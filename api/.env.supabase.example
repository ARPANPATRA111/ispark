# iSPARC — cloud/staging environment TEMPLATE.
#
# Copy to api/.env.supabase (gitignored) and fill in the real values, then run
# the API against the cloud stack instead of the local Docker database:
#
#   PowerShell:  $env:ENV_FILE=".env.supabase"; go run .
#   Bash:        ENV_FILE=.env.supabase go run .
#
# The same values go into the Render service's Environment tab.

PORT=8080

# --- Supabase Postgres ---
# Dashboard -> Connect -> Session pooler (IPv4, port 5432).
# The user is postgres.<project-ref>; the pooler host region prefix matters
# (e.g. aws-1-ap-south-1), so copy it from the dashboard rather than guessing.
#
# Alternatively set DATABASE_URL to the full connection string and omit every
# DB_* value below — one field is harder to get wrong than six:
# DATABASE_URL=postgresql://postgres.ref:password@host:5432/postgres?sslmode=require
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_database_password
DB_NAME=postgres
DB_SSLMODE=require
# true only when using the transaction pooler (port 6543)
DB_PREFER_SIMPLE_PROTOCOL=false

# --- JWT secrets (use long random values; Render can generate them) ---
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret

# --- Vercel Blob (use a PRIVATE store) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
BLOB_ACCESS=private

# --- SMTP for real OTP emails (e.g. Brevo). Leave blank to log OTPs instead. ---
# SMTP_SENDER must be an address verified with the provider.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_login
SMTP_PASS=your_smtp_key
SMTP_SENDER=verified_sender@example.com

# --- CORS: the deployed web origin(s), comma-separated ---
ALLOWED_ORIGINS=https://your-app.vercel.app

# true for the very first boot (creates demo data), false afterwards
SEED_DEV_DATA=false
